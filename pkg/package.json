{
  "name": "hermes-ambit-deployer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/shared",
    "packages/gcp",
    "packages/azure",
    "packages/tui"
  ],
  "scripts": {
    "check": "tsc -b packages/shared packages/gcp packages/azure packages/tui",
    "test": "bun test",
    "generate:clients": "bun run prepare:openapi && orval --config orval.config.ts",
    "prepare:openapi": "bun run scripts/prepare-openapi.ts",
    "nix:update": "bun2nix -o bun.nix"
  },
  "devDependencies": {
    "orval": "^7.13.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "effect": "^3.17.0",
    "zod": "^4.1.0"
  }
}
