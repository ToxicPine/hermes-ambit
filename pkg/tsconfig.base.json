{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "exactOptionalPropertyTypes": true,
    "baseUrl": ".",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@cardelli/azure": ["packages/azure/src/index.ts"],
      "@cardelli/gcp": ["packages/gcp/src/index.ts"],
      "@cardelli/shared": ["packages/shared/src/index.ts"]
    },
    "strict": true,
    "target": "ES2022",
    "verbatimModuleSyntax": true
  }
}
