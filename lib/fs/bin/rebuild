#!/usr/bin/env bash
set -euo pipefail

APP=/opt/app
user="${USER:?USER must be set}"
home_nix="${APP}/hm-user/${user}/home.nix"

if [ ! -f "$home_nix" ]; then
  echo "rebuild: no home.nix found at $home_nix" >&2
  exit 1
fi

result=$(nix-build --no-out-link -E "
  let
    sources = import ${APP}/hm-base/npins;
    pkgs    = import sources.nixpkgs { };
    hm      = import sources.home-manager { inherit pkgs; };
  in (hm.lib.homeManagerConfiguration {
    inherit pkgs;
    modules = [
      ${home_nix}
      { home.username = \"${user}\"; home.homeDirectory = \"/home/${user}\"; }
    ];
  }).activationPackage
")

"$result/activate"
