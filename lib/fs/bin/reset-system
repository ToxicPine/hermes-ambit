#!/usr/bin/env bash
set -euo pipefail

APP="${HERMES_AMBIT_APP:-/opt/app}"
DEFAULTS="${HERMES_AMBIT_DEFAULTS:-/opt/defaults}"
DATA="${HERMES_AMBIT_DATA:-/data}"
command_name="reset-system"
refresh=1
original_args=("$@")

usage() {
  cat >&2 <<EOF
Usage: ${command_name} [--no-refresh]

Reset the current user's ~/.nixcfg Home Manager config to factory defaults.
EOF
}

while [[ "$#" -gt 0 ]]; do
  case "$1" in
  --no-refresh)
    refresh=0
    ;;
  -h | --help)
    usage
    exit 0
    ;;
  *)
    usage
    exit 2
    ;;
  esac
  shift
done

user="${HERMES_AMBIT_USER:-${USER:-}}"
if [[ -z "${user}" ]] || { [[ "${user}" = "root" ]] && [[ -z "${HERMES_AMBIT_USER:-}" ]]; }; then
  echo "${command_name}: set HERMES_AMBIT_USER when running as root" >&2
  exit 1
fi

uid="$(jq -r --arg u "${user}" '.[] | select(.name == $u) | .uid' /etc/users.json)"
if [[ -z "${uid}" ]] || [[ "${uid}" = "null" ]]; then
  echo "${command_name}: unknown user ${user}" >&2
  exit 1
fi

current_uid="$(id -u)"
if [[ "${current_uid}" != "${uid}" ]]; then
  if [[ "${current_uid}" != "0" ]]; then
    echo "${command_name}: run as ${user} or as root with HERMES_AMBIT_USER=${user}" >&2
    exit 1
  fi

  persist="${DATA}/homes/${user}"
  mkdir -p "${persist}" "${APP}/hm-user"
  chown "${uid}:${uid}" "${persist}"
  rm -rf "${APP}/hm-user/${user}"
  ln -snf "${persist}/nixcfg" "${APP}/hm-user/${user}"

  exec setpriv --reuid="${uid}" --regid="${uid}" --init-groups \
    env HOME="/home/${user}" USER="${user}" PATH="${PATH}" HERMES_AMBIT_USER="${user}" \
    HERMES_AMBIT_APP="${APP}" HERMES_AMBIT_DEFAULTS="${DEFAULTS}" HERMES_AMBIT_DATA="${DATA}" \
    "$0" "${original_args[@]}"
fi

persist="${DATA}/homes/${user}"
nixcfg="${persist}/nixcfg"
factory="${DEFAULTS}/hm-user/${user}"

if [[ ! -d "${factory}" ]]; then
  echo "${command_name}: no default Home Manager config found at ${factory}" >&2
  exit 1
fi

mkdir -p "${persist}"
tmp="$(mktemp -d "${persist}/.nixcfg-reset.XXXXXX")"
cleanup() {
  rm -rf "${tmp}"
}
trap cleanup EXIT

cp -R "${factory}/." "${tmp}/"
chmod -R u+rwX "${tmp}"
rm -rf "${nixcfg}"
mv "${tmp}" "${nixcfg}"
trap - EXIT

echo "Reset ${nixcfg} from ${factory}"

if [[ "${refresh}" = "1" ]]; then
  "${APP}/bin/refresh-system"
else
  echo "Skipped refresh; run refresh-system to activate the reset config."
fi
